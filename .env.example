# Example operator environment for model-benchmarking.
# Copy to .env (gitignored) and fill in the values you need.
# Nothing auto-loads this file: export the variables into the shell
# before invoking `model-benchmark`.

# ── Functional V1 operator contract (required for preflight/run) ─────────────
# Real provider credential for the operator-selected OpenAI-compatible
# Provider Route. It exists only in the host environment and the Credential
# Proxy; conditions receive an opaque per-Trial proxy token instead.
# `preflight` and `run` fail closed with provider-credential-missing when
# this is unset.
MODEL_BENCHMARK_PROVIDER_API_KEY=

# ── Acceptance harness (optional) ────────────────────────────────────────────
# Required only when running the acceptance suites with `pytest --run-live`.
MODEL_BENCHMARK_LIVE_ATTESTATION=

# ── Legacy run_benchmark.py flow (optional) ──────────────────────────────────
OPENROUTER_API_KEY=
OPENCODE_API_KEY=
OPENCODE_GO_API_KEY=
# Model selector used by run_benchmark.py when --models is omitted.
BENCHMARK_MODELS=
# Benchmark workdir cache: seeded task snapshots are stored once and each
# run clones its isolated workdir from this path (APFS copy-on-write when
# available).
BENCHMARK_WORKDIR_CACHE=
