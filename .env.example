# Copy to .env (gitignored), fill in, and export into the shell —
# nothing auto-loads this file.

# ── Functional V1 (required) ─────────────────────────────────────────────────
# Real provider credential. Conditions never see it; they get an opaque
# per-Trial proxy token. The route and exact model go in the run manifest,
# not here, e.g. for DeepSeek V4 Flash through OpenCode Go:
#   provider:
#     base_url: https://opencode.ai/zen/go/v1
#     model: deepseek-v4-flash
MODEL_BENCHMARK_PROVIDER_API_KEY=sk-or-v1-replace-me

# ── Acceptance suites (optional) ─────────────────────────────────────────────
# Only for `pytest --run-live`: path to the live prerequisite attestation.
MODEL_BENCHMARK_LIVE_ATTESTATION=artifacts/attestation/live-attestation.json

# ── OpenCode Go model selection (optional) ───────────────────────────────────
OPENCODE_GO_API_KEY=sk-or-v1-replace-me
BENCHMARK_MODELS=deepseek-v4-flash,hy3,minimax-m3
BENCHMARK_WORKDIR_CACHE=~/.cache/model-benchmark-workdirs
