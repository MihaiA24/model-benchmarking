  "broad_development_slice": "broad",
  "development_slices": [
    {
      "id": "architecture",
      "authority": "none",
      "commands": [
        "uv run --offline --frozen pytest -q tests/architecture --maxfail=1"
      ]
    },
    {
      "id": "broad",
      "authority": "none",
      "commands": [
        "uv run --offline --frozen pytest -q tests/unit tests/architecture --maxfail=1",
        "uv lock --check",
        "python -m compileall -q src scripts verification"
      ]
    },
    {
      "id": "cli",
      "authority": "none",
      "commands": [
        "uv run --offline --frozen pytest -q tests/unit/test_cli.py --maxfail=1"
