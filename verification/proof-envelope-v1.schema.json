{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "authority": {
      "const": "fresh_authoritative"
    },
    "candidate_sha": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    },
    "child_artifacts": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "path": {
            "minLength": 1,
            "type": "string"
          },
          "sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          }
        },
        "required": [
          "path",
          "sha256"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "commands": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "cases": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "id": {
                  "minLength": 1,
                  "type": "string"
                },
                "outcome": {
                  "enum": [
                    "passed",
                    "failed",
                    "skipped",
                    "xfailed"
                  ]
                }
              },
              "required": [
                "id",
                "outcome"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "command": {
            "minLength": 1,
            "type": "string"
          },
          "completed_at": {
            "format": "date-time",
            "type": "string"
          },
          "exit_code": {
            "type": "integer"
          },
          "id": {
            "minLength": 1,
            "type": "string"
          },
          "outcome": {
            "enum": [
              "passed",
              "failed",
              "cancelled",
              "timed_out"
            ]
          },
          "started_at": {
            "format": "date-time",
            "type": "string"
          },
          "timeout_seconds": {
            "minimum": 1,
            "type": "integer"
          }
        },
        "required": [
          "cases",
          "command",
          "completed_at",
          "exit_code",
          "id",
          "outcome",
          "started_at",
          "timeout_seconds"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "gate_id": {
      "minLength": 1,
      "type": "string"
    },
    "generation_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "policy_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "repository": {
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
      "type": "string"
    },
    "schema_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "source_tree_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "worker": {
      "additionalProperties": false,
      "properties": {
        "class": {
          "minLength": 1,
          "type": "string"
        },
        "docker_daemon": {
          "type": [
            "string",
            "null"
          ]
        },
        "identity": {
          "minLength": 1,
          "type": "string"
        },
        "qualification_state": {
          "const": "qualified"
        }
      },
      "required": [
        "class",
        "docker_daemon",
        "identity",
        "qualification_state"
      ],
      "type": "object"
    },
    "workflow": {
      "additionalProperties": false,
      "properties": {
        "check_run_id": {
          "minimum": 1,
          "type": "integer"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "reason": {
          "minLength": 1,
          "type": "string"
        },
        "requester": {
          "minLength": 1,
          "type": "string"
        },
        "run_attempt": {
          "minimum": 1,
          "type": "integer"
        },
        "run_id": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "check_run_id",
        "path",
        "reason",
        "requester",
        "run_attempt",
        "run_id"
      ],
      "type": "object"
    }
  },
  "required": [
    "authority",
    "candidate_sha",
    "child_artifacts",
    "commands",
    "created_at",
    "gate_id",
    "generation_id",
    "policy_sha256",
    "repository",
    "schema_sha256",
    "source_tree_sha256",
    "version",
    "worker",
    "workflow"
  ],
  "title": "Model Benchmark trusted runner proof envelope v1",
  "type": "object"
}
